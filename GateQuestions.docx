//Gate Questions related to function and recursion.
Q1.  What is the output?
#include <iostream>
using namespace std;

void fun()
{
    static int x = 0;
    x++;
    cout << x << " ";
}

int main()
{
    fun();
    fun();
    fun();
}

Ans. 1 2 3
A static variable is created only once and retains its value throughout the program.

Q2.What is the output of fun(4)?

 void fun(int n)
{
    if(n == 0)
        return;

    cout << n;
    fun(n-1);
    cout << n;
}

Ans. 43211234

Q3. Find fun(4).
int fun(int n)
{
    if(n==0)
        return 0;

    return n + fun(n-1);
}

Ans. 4 + 3 + 2 + 1 + 0 = 10

Q4. How many times is fun() called when fun(5) is executed?
void fun(int n)
{
    if(n<=0)
        return;

    fun(n-1);
}

Ans. Calls:

fun(5)
fun(4)
fun(3)
fun(2)
fun(1)
fun(0)

Total = 6 calls

Q5. Find fun(4,3).
int fun(int a, int b)
{
    if(b==0)
        return 0;

    return a + fun(a,b-1);
}

Ans.4+4+4=12

Q6. Output of A(3)?
void B(int);

void A(int n)
{
    if(n<=0) return;
    cout<<"A";
    B(n-1);
}

void B(int n)
{
    if(n<=0) return;
    cout<<"B";
    A(n-1);
}

Ans. ABA

